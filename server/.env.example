# Copy this file to .env and fill in your values

# MongoDB Atlas connection string (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aman-portfolio

# Port for the API server
PORT=5000

# Admin login password (used at /admin)
ADMIN_PASSWORD=change-me-strong-password

# Secret for signing JWT tokens (any long random string)
JWT_SECRET=change-me-long-random-secret

# Frontend origin for CORS (production URL after deployment)
CLIENT_ORIGIN=http://localhost:5173
